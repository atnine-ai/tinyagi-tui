{
  "name": "tinyagi-tui",
  "version": "0.1.0",
  "description": "Full-screen terminal dashboard for monitoring TinyAGI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tinyagi-tui": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.tsx",
    "dev": "tsx --watch src/index.tsx",
    "mock": "tsx src/index.tsx --mock",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.8",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
